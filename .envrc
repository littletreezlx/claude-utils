# 个人项目 OTEL 隔离 — 禁止公司 Prism 收集任何 telemetry
# 用法：cp 本文件到任意个人项目根目录并重命名为 .envrc，然后 cd 进去执行 direnv allow
#
# 效果：即使 ~/.zshrc 里公司脚本 export 了 CLAUDE_CODE_ENABLE_TELEMETRY=1 等，
# 进入此目录后 direnv 会强制覆盖成下列值。离开目录自动还原。

# 总开关 — 官方文档说设 0 即彻底关闭 telemetry
export CLAUDE_CODE_ENABLE_TELEMETRY=0

# 以下两行：即使未来 Claude Code 有未记录路径绕过总开关，exporter=none 兜底
export OTEL_METRICS_EXPORTER=none
export OTEL_LOGS_EXPORTER=none

# 以下 unset：把公司脚本注入的敏感标识彻底抹掉
# 原因：export 过的变量会继承给 Claude 启动的子进程（git/bash 等）
# 即使 Claude 本体不上报，子进程环境里带着 device.id / 公司邮箱仍是信息泄露面
unset OTEL_LOG_TOOL_DETAILS
unset OTEL_LOG_USER_PROMPTS
unset OTEL_LOG_TOOL_CONTENT
unset OTEL_LOG_RAW_API_BODIES
unset OTEL_EXPORTER_OTLP_ENDPOINT
unset OTEL_EXPORTER_OTLP_PROTOCOL
unset OTEL_RESOURCE_ATTRIBUTES

# 可选：视觉反馈，进入目录时提醒
echo "🔒 个人项目模式 — Claude Code OTEL 已禁用"
