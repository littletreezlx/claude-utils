{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(./gradlew compileDebugKotlin:*)",
      "Bash(find:*)",
      "Bash(rm:*)",
      "Bash(./gradlew:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(rg:*)",
      "Bash(timeout:*)",
      "Bash(kotlinc:*)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(git log:*)"
    ],
    "deny": [],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/start-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-call.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "MiniMax": {
      "command": "uvx",
      "args": [
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "env": {
        "MINIMAX_API_KEY": "sk-cp-74m9QxrVIY3s3cOOrflLcyAgyVv1IeM9ffzARalrFclsECUiHzdwUIjZ_jKGqfPcryqIcV2Rdjh492qSGNWdvzIIOecdMC5L0acnESWAbbMSEh91OABW1mU",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      }
    }
  },
  "CLAUDE_CODE_AUTO_COMPACT_WINDOW": 400000
}
