{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(./gradlew compileDebugKotlin:*)",
      "Bash(find:*)",
      "Bash(rm:*)",
      "Bash(./gradlew:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(rg:*)",
      "Bash(timeout:*)",
      "Bash(kotlinc:*)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(git log:*)",
      "mcp__pencil"
    ],
    "deny": [],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-call.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "pencil": {
      "command": "/Users/zhanglingxiao/.pencil/mcp/visual_studio_code/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "visual_studio_code"
      ]
    },
    "MiniMax": {
      "command": "uvx",
      "args": ["minimax-coding-plan-mcp", "-y"],
      "env": {
        "MINIMAX_API_KEY": "sk-cp-74m9QxrVIY3s3cOOrflLcyAgyVv1IeM9ffzARalrFclsECUiHzdwUIjZ_jKGqfPcryqIcV2Rdjh492qSGNWdvzIIOecdMC5L0acnESWAbbMSEh91OABW1mU",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "CLAUDE_CODE_AUTO_COMPACT_WINDOW": 400000
}